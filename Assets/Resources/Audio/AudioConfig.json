    "settlement_bgm":  { "volume": 0.6, "loop": true,  "comment": "结算/地图BGM" },
    "victory_bgm":     { "volume": 0.7, "loop": false, "comment": "胜利BGM" },
    "defeat_bgm":      { "volume": 0.6, "loop": false, "comment": "失败BGM" },
    "calm_bgm":        { "volume": 0.5, "loop": true,  "comment": "默认场景BGM" }
  },

  "sfx_battle": {
    "sfx_battle_start": { "volume": 1.0, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.5,  "comment": "战斗开始号角" },
    "sfx_hit":          { "volume": 0.8, "pitchMin": 0.9, "pitchMax": 1.1, "minInterval": 0.1,  "comment": "普攻命中" },
    "sfx_crit":         { "volume": 1.0, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.1,  "comment": "暴击命中（主音）" },
    "sfx_crit_impact":  { "volume": 0.9, "pitchMin": 0.85,"pitchMax": 1.15,"minInterval": 0.1,  "comment": "暴击冲击（随机pitch叠加层）" },
    "sfx_heal":         { "volume": 0.7, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.1,  "comment": "治疗音效" },
    "sfx_shield":       { "volume": 0.7, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.1,  "comment": "护盾音效" },
    "sfx_death":        { "volume": 0.9, "pitchMin": 0.9, "pitchMax": 1.1, "minInterval": 0.3,  "comment": "单位死亡" },
    "sfx_victory":      { "volume": 1.0, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 1.0,  "comment": "胜利号角" },
    "sfx_defeat":       { "volume": 0.8, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 1.0,  "comment": "失败音效" }
