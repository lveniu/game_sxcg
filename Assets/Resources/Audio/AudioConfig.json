  "sfx_dice": {
    "sfx_dice_roll":    { "volume": 0.8, "pitchMin": 0.95,"pitchMax": 1.05,"minInterval": 0.05, "comment": "骰子落地单次音" },
    "sfx_dice_lock":    { "volume": 0.6, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.05, "comment": "骰子锁定音效" },
    "sfx_dice_spin":    { "volume": 0.5, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.15, "comment": "骰子旋转音效" }
  },

  "sfx_combo": {
    "sfx_combo_pair":   { "volume": 0.9, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.2,  "comment": "对子技能触发（常见）" },
    "sfx_combo_straight":{ "volume": 1.0, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.2, "comment": "顺子技能触发（稀有）" },
    "sfx_combo_three":  { "volume": 1.0, "pitchMin": 1.0, "pitchMax": 1.0, "minInterval": 0.2,  "comment": "三条技能触发（史诗）" }
