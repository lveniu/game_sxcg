{
  "_version": "1.0.0",
  "_description": "经验升级系统: 经验获取、升级表、升星表",
  "exp_sources": {
    "level_clear_base": {
      "formula": "10 * level",
      "description_cn": "通关基础经验",
      "distribution": "all_alive_heroes_evenly"
    },
    "kill_enemy": {
      "value": 5,
      "description_cn": "击杀敌人经验",
      "distribution": "killing_hero_gets_all"
    },
    "boss_kill_bonus": {
      "value": 30,
      "description_cn": "Boss击杀额外经验",
      "distribution": "all_alive_heroes_evenly"
    },
    "event_bonus_multiplier": {
      "value": 1.5,
      "chance": 0.1,
      "description_cn": "随机事件: 经验+50%"
    }
  },
  "exp_table": {
    "_description": "每级所需经验(从上一级到本级), 公式: 20 + (level-1)*30 + MAX(0, level-6)*20",
