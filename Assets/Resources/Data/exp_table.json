      {"level": 6, "exp_to_next": 190, "cumulative": 590, "est_level_at": 11, "note": "增速加快"},
      {"level": 7, "exp_to_next": 220, "cumulative": 810, "est_level_at": 13, "note": ""},
      {"level": 8, "exp_to_next": 250, "cumulative": 1060, "est_level_at": 16, "note": ""},
      {"level": 9, "exp_to_next": 280, "cumulative": 1340, "est_level_at": 18, "note": ""},
      {"level": 10, "exp_to_next": 310, "cumulative": 1650, "est_level_at": 21, "note": "成长放缓"},
      {"level": 11, "exp_to_next": 340, "cumulative": 1990, "est_level_at": 24, "note": ""},
      {"level": 12, "exp_to_next": 370, "cumulative": 2360, "est_level_at": 27, "note": ""},
