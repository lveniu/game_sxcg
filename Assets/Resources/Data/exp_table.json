    "formula": "exp_to_next(lvl) = 20 + (lvl - 1) * 30 + MAX(0, lvl - 6) * 20",
    "max_level": 0,
    "_note": "max_level=0 表示无等级上限"
  },
  "star_upgrade": {
    "_description": "升星系统: 2合1",
